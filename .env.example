# =============================================================
# BiblioHome — Variáveis de Ambiente (Backend)
# =============================================================
# Copie este arquivo para .env e preencha com suas credenciais:
#   cp .env.example .env
# =============================================================

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Google Books API (opcional, melhora busca de metadados)
GOOGLE_BOOKS_API_KEY=sua_google_books_api_key_aqui

# Servidor
PORT=3001
